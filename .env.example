# === Telegram ===
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
OWNER_TELEGRAM_ID=your_telegram_user_id

# === Supabase ===
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key   # service_role, BUKAN anon key

# B1: connection string Postgres untuk backup/pg_dump → WAJIB port 6543 (PgBouncer) + ?pgbouncer=true
# supabase-py REST client cukup pakai SUPABASE_URL + SERVICE_KEY di atas.
SUPABASE_DB_URL=postgresql://postgres.your-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# === Auth ===
AUTH_SECRET=64_char_random_hex_string_for_hmac   # generate: python -c "import secrets;print(secrets.token_hex(32))"

# === Frontend (di-set di Vercel env vars; prod biarkan kosong = same-origin) ===
VITE_API_URL=
