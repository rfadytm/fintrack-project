# === Telegram ===
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather   # bentuk: 1234567890:AAF...
OWNER_TELEGRAM_ID=your_numeric_telegram_id          # ANGKA, dari @userinfobot

# === Supabase ===
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_xxx   # Secret key (format baru) ATAU service_role JWT legacy

# Connection string Postgres untuk migrasi (scripts/migrate.py) & backup (pg_dump).
# Pakai Transaction/Session pooler. JANGAN tambah ?pgbouncer=true (libpq/psql/pg_dump menolaknya).
SUPABASE_DB_URL=postgresql://postgres.your-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# === Auth ===
AUTH_SECRET=64_char_random_hex_string_for_hmac   # generate: python -c "import secrets;print(secrets.token_hex(32))"
WEBHOOK_SECRET=random_hex_for_telegram_webhook   # anti-spoofing; generate: python -c "import secrets;print(secrets.token_hex(24))"

# === App URL (isi setelah deploy Vercel; dipakai /getlink) ===
APP_URL=

# === Frontend (di-set di Vercel env vars; prod biarkan kosong = same-origin) ===
VITE_API_URL=
